{
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "Node10",
		"ignoreDeprecations": "6.0",
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"types": ["node"],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"rootDir": ".",
		"outDir": ".test-dist"
	},
	"include": [
		"src/view/editorTestUtils.ts",
		"src/view/exportHtml.ts",
		"src/view/extendedTableMatchers.ts",
		"src/view/multiRowHeaderPlugin.ts",
		"src/view/strikethroughLogic.ts",
		"src/view/syncDebugLog.ts",
		"test/unit/**/*.ts",
		"test/smoke/**/*.ts"
	]
}
